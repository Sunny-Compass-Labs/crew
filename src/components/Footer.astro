---
const links = [
  { href: '/', label: 'Home' },
  { href: '/about', label: 'About' },
  { href: '/products', label: 'Products' },
  { href: '/weather', label: 'Weather' },
];
---

<footer class="relative bg-ocean-navy text-cream mt-auto">
  <!-- Wave SVG divider -->
  <div class="absolute -top-16 left-0 w-full overflow-hidden leading-none">
    <svg class="relative block w-[200%] h-16 animate-wave" viewBox="0 0 1200 60" preserveAspectRatio="none">
      <path d="M0,30 C200,60 400,0 600,30 C800,60 1000,0 1200,30 L1200,60 L0,60 Z" fill="#0B1D3A" />
    </svg>
  </div>

  <div class="max-w-6xl mx-auto px-4 pt-12 pb-8">
    <div class="grid md:grid-cols-3 gap-8 mb-8">
      <!-- Brand -->
      <div>
        <h3 class="font-display text-2xl text-gold mb-3">Sunny Compass Labs</h3>
        <p class="text-sand/80 text-sm">Navigating the seas of innovation, charting courses to new horizons.</p>
      </div>

      <!-- Navigation -->
      <div>
        <h4 class="font-body font-bold text-teal mb-3 uppercase tracking-wider text-sm">Navigate</h4>
        <ul class="space-y-2">
          {links.map((link) => (
            <li>
              <a href={link.href} class="text-sand/80 hover:text-gold transition-colors text-sm">
                {link.label}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Decorative -->
      <div class="flex items-center justify-center md:justify-end">
        <svg class="w-16 h-16 text-gold/30" viewBox="0 0 100 100" fill="none" stroke="currentColor" stroke-width="2">
          <circle cx="50" cy="50" r="40" />
          <circle cx="50" cy="50" r="3" fill="currentColor" />
          <line x1="50" y1="10" x2="50" y2="30" stroke-width="3" />
          <line x1="50" y1="70" x2="50" y2="90" />
          <line x1="10" y1="50" x2="30" y2="50" />
          <line x1="70" y1="50" x2="90" y2="50" />
          <text x="50" y="8" text-anchor="middle" fill="currentColor" font-size="10" stroke="none">N</text>
          <text x="50" y="99" text-anchor="middle" fill="currentColor" font-size="10" stroke="none">S</text>
          <text x="3" y="54" text-anchor="middle" fill="currentColor" font-size="10" stroke="none">W</text>
          <text x="97" y="54" text-anchor="middle" fill="currentColor" font-size="10" stroke="none">E</text>
        </svg>
      </div>
    </div>

    <div class="border-t border-teal/20 pt-6 text-center text-sand/60 text-sm">
      <p>&copy; 2026 Sunny Compass Labs. All rights reserved.</p>
    </div>
  </div>
</footer>
