<section class="py-20 px-4 bg-cream">
  <div class="max-w-4xl mx-auto text-center">
    <div class="flex justify-center mb-6">
      <svg class="w-12 h-12 text-amber" viewBox="0 0 100 100" fill="none" stroke="currentColor" stroke-width="2">
        <path d="M50,80 C50,80 20,60 20,40 Q20,10 50,15 Q80,10 80,40 C80,60 50,80 50,80Z" fill="currentColor" opacity="0.15" />
        <path d="M50,80 C50,80 20,60 20,40 Q20,10 50,15 Q80,10 80,40 C80,60 50,80 50,80Z" />
        <line x1="50" y1="15" x2="50" y2="80" stroke-width="1.5" />
      </svg>
    </div>

    <h2 class="font-display text-4xl md:text-5xl text-ocean-navy mb-6">Our Story</h2>

    <p class="text-lg text-cerulean/80 max-w-2xl mx-auto mb-8 leading-relaxed">
      Born from a spirit of adventure, Sunny Compass Labs was founded to navigate the vast ocean of untapped potential.
      We believe the best discoveries come from those bold enough to sail beyond the horizon.
    </p>

    <a
      href="/about"
      class="inline-flex items-center gap-2 text-gold hover:text-amber font-bold text-lg transition-colors group"
    >
      Learn more about our voyage
      <svg class="w-5 h-5 group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
      </svg>
    </a>
  </div>
</section>
