---
interface Props {
  name: string;
  tagline: string;
  status: 'coming-soon' | 'available' | 'discontinued';
  image?: string;
}

const { name, tagline, status, image } = Astro.props;
---

<div class="relative group bg-white rounded-xl border-2 border-sand hover:border-gold shadow-md hover:shadow-xl transition-all duration-300 hover:-translate-y-2 overflow-hidden">
  {/* Image or placeholder */}
  <div class="h-48 bg-gradient-to-br from-cerulean/20 to-teal/20 flex items-center justify-center overflow-hidden">
    {image ? (
      <img src={image} alt={name} class="w-full h-full object-cover" />
    ) : (
      <svg class="w-16 h-16 text-cerulean/40" viewBox="0 0 100 100" fill="none" stroke="currentColor" stroke-width="2">
        <path d="M50,15 L50,5 M50,95 L50,85 M5,50 L15,50 M85,50 L95,50" />
        <circle cx="50" cy="50" r="30" />
        <circle cx="50" cy="50" r="3" fill="currentColor" />
        <line x1="50" y1="20" x2="50" y2="35" stroke-width="3" />
      </svg>
    )}
  </div>

  {/* Coming soon badge */}
  {status === 'coming-soon' && (
    <div class="absolute top-3 right-3 bg-gold text-ocean-navy text-xs font-bold px-3 py-1 rounded-full uppercase tracking-wider">
      Coming Soon
    </div>
  )}

  {/* Card content */}
  <div class="p-6 border-t-2 border-gold/30">
    <h3 class="font-display text-2xl text-ocean-navy mb-2">{name}</h3>
    <p class="text-cerulean/80 text-sm">{tagline}</p>
  </div>
</div>
