---
import BaseLayout from '@layouts/BaseLayout.astro';
import ProductCard from '@components/ProductCard.astro';

const products = [
  { name: 'Compass Navigator', tagline: 'AI-powered wayfinding for complex decisions.', status: 'coming-soon' as const },
  { name: 'Tide Tracker', tagline: 'Real-time analytics that ride the wave of your data.', status: 'coming-soon' as const },
  { name: 'Harbor Suite', tagline: 'A safe port for your most critical workflows.', status: 'coming-soon' as const },
  { name: 'Starboard Engine', tagline: 'High-performance compute for your heaviest workloads.', status: 'coming-soon' as const },
];
---

<BaseLayout title="Products - Sunny Compass Labs" description="Explore the innovative products being built at Sunny Compass Labs.">
  {/* Page header */}
  <section class="bg-gradient-to-b from-ocean-navy to-cerulean py-24 px-4 text-center">
    <h1 class="font-display text-5xl md:text-7xl text-gold mb-4 animate-sail-in">Our Fleet</h1>
    <p class="text-sand/80 text-xl max-w-2xl mx-auto animate-fade-in-up animate-delay-1">
      Products designed to navigate complexity and chart a course to clarity.
    </p>
  </section>

  {/* Products grid */}
  <section class="py-20 px-4 bg-cream">
    <div class="max-w-6xl mx-auto">
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
        {products.map((product, i) => (
          <div class:list={['animate-fade-in-up', `animate-delay-${i + 1}`]}>
            <ProductCard {...product} />
          </div>
        ))}
      </div>
    </div>
  </section>
</BaseLayout>
